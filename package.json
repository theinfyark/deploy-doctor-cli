{
  "name": "deploy-doctor-cli",
  "version": "1.0.0",
  "description": "Deployment validation CLI — checks Docker, Kubernetes, Helm, Terraform, cloud CLIs, Git, Node, disk, memory, ports, and networking.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "deploy-doctor": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean --sourcemap && node scripts/fix-cli.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "deployment",
    "docker",
    "kubernetes",
    "terraform",
    "devops",
    "cli",
    "azure",
    "aws"
  ],
  "author": "Anil Kumar <anilachary67@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theinfyark/deploy-doctor-cli.git"
  },
  "bugs": {
    "url": "https://github.com/theinfyark/deploy-doctor-cli/issues"
  },
  "homepage": "https://github.com/theinfyark/deploy-doctor-cli#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/anilachary"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.3"
  }
}
